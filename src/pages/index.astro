---
import SiteLayout from '../layouts/SiteLayout.astro';
import SiteIntro from '../components/home/SiteIntro.astro';
import FeaturedProjects from '../components/home/FeaturedProjects.astro';
import AllProjects from '../components/home/AllProjects.astro';
import { getProjects } from '../lib/projects/registry';

const allProjects = getProjects();
const featured = allProjects.filter((p) => p.featured);
---

<SiteLayout title="ToyWebCreations">
  <SiteIntro />
  <FeaturedProjects projects={featured} />
  <AllProjects projects={allProjects} />
</SiteLayout>
