---
import SiteLayout from '../layouts/SiteLayout.astro';
import { REPO_ROOT } from '../lib/github';
---

<SiteLayout
  title="About | ToyWebCreations"
  description="What ToyWebCreations is, why it exists, and how it's built."
>
  <div class="about-page">
    <div class="container">
      <header class="about-header">
        <p class="about-label">/ about</p>
        <h1 class="about-title">About ToyWebCreations</h1>
      </header>

      <div class="about-body">
        <section class="about-section">
          <h2>What is this?</h2>
          <p>
            ToyWebCreations is a collection of small, focused, interactive web projects —
            puzzles, simulations, generators, and visual experiments. Each one is
            self-contained, playable in the browser, and built to be tried immediately.
          </p>
          <p>
            The site is not a blog. It's a hub for demos. The closest thing to writing
            is each project's About page, where the concept is explained and
            implementation notes live.
          </p>
        </section>

        <section class="about-section">
          <h2>Why does it exist?</h2>
          <p>
            One-off projects accumulate. ToyWebCreations is a place to consolidate
            them into something coherent and public-facing — a portfolio that
            demonstrates how things actually work by letting you interact with them.
          </p>
          <p>
            The "toy" framing is intentional. These aren't polished products.
            They're focused experiments: interesting enough to build,
            interesting enough to try.
          </p>
        </section>

        <section class="about-section">
          <h2>How is it built?</h2>
          <p>
            Static site built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>,
            deployed to GitHub Pages. Interactive demos are React islands —
            project-specific code only loads on the relevant project page.
            No backend, no tracking, no accounts.
          </p>
          <p>
            Source code lives on <a href={REPO_ROOT} target="_blank" rel="noopener noreferrer">GitHub</a>.
          </p>
        </section>
      </div>
    </div>
  </div>
</SiteLayout>

<style>
  .about-page {
    padding: var(--space-16) 0 var(--space-20);
  }

  .about-header {
    margin-bottom: var(--space-12);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-8);
  }

  .about-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .about-title {
    font-family: var(--font-display);
    font-size: var(--text-6xl);
    color: var(--phosphor);
    text-shadow: var(--glow-text-md);
    letter-spacing: 0.03em;
  }

  .about-body {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .about-section h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--phosphor-muted);
    margin-bottom: var(--space-5);
    letter-spacing: 0.04em;
  }

  .about-section p {
    color: var(--text);
    font-size: var(--text-base);
    line-height: 1.75;
    margin-bottom: var(--space-4);
  }

  .about-section p:last-child {
    margin-bottom: 0;
  }
</style>
