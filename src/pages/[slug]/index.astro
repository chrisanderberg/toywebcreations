---
import ConwayDemo from "../../projects/conway/Demo";
import ElementaryCellularAutomataDemo from "../../projects/elementary-cellular-automata/Demo";
import SudokuDemo from "../../projects/sudoku/Demo";
import TowerOfHanoiDemo from "../../projects/tower-of-hanoi/Demo";
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import { getProjectRecords } from "../../lib/projects/registry";

export function getStaticPaths() {
  return getProjectRecords().map((record) => ({
    params: { slug: record.meta.slug },
    props: { project: record.meta }
  }));
}

const { project } = Astro.props;
const demoComponents = {
  sudoku: SudokuDemo,
  conway: ConwayDemo,
  "elementary-cellular-automata": ElementaryCellularAutomataDemo,
  "tower-of-hanoi": TowerOfHanoiDemo
} as const;
const DemoComponent = demoComponents[project.slug as keyof typeof demoComponents];
---

<ProjectLayout project={project}>
  <section class="demo-shell">
    {DemoComponent ? <DemoComponent client:load /> : <p>Demo unavailable for this project.</p>}
  </section>
</ProjectLayout>
