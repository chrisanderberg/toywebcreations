---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import { getProjects } from "../../lib/projects/registry";
import type { ProjectMeta } from "../../lib/projects/types";
import SudokuAbout from "../../projects/sudoku/about.mdx";
import ConwayAbout from "../../projects/conway/about.mdx";
import ElementaryCellularAutomataAbout from "../../projects/elementary-cellular-automata/about.mdx";
import TowerOfHanoiAbout from "../../projects/tower-of-hanoi/about.mdx";

const aboutBySlug: Record<string, typeof SudokuAbout> = {
  sudoku: SudokuAbout,
  conway: ConwayAbout,
  "elementary-cellular-automata": ElementaryCellularAutomataAbout,
  "tower-of-hanoi": TowerOfHanoiAbout
};

export function getStaticPaths() {
  return getProjects().map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

interface Props {
  project: ProjectMeta;
}

const { project } = Astro.props;
const AboutDoc = aboutBySlug[project.slug];
if (!AboutDoc) {
  throw new Error(`No about document for slug "${project.slug}"`);
}
---

<ProjectLayout project={project} variant="about">
  <article class="project-about-prose">
    <AboutDoc />
  </article>
</ProjectLayout>

<style is:global>
  .project-about-prose h1 {
    margin-top: 0;
    color: var(--color-accent);
    text-shadow: var(--glow-accent);
    font-size: 1.75rem;
  }

  .project-about-prose h2 {
    margin-top: 2rem;
    font-size: 1.15rem;
    color: var(--color-text);
  }

  .project-about-prose p,
  .project-about-prose li {
    color: var(--color-text);
    max-width: 42rem;
  }

  .project-about-prose a {
    color: var(--color-accent);
  }

  .project-about-prose code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-bg-elevated);
    padding: 0.1em 0.35em;
    border-radius: 4px;
  }
</style>
