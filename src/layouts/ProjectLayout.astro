---
import SiteLayout from "./SiteLayout.astro";
import type { ProjectMeta } from "../lib/projects/types";

interface Props {
  project: ProjectMeta;
  variant?: "demo" | "about";
}

const { project, variant = "demo" } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const demoHref = `${base}${project.slug}/`;
const aboutHref = `${base}${project.slug}/about/`;
const title =
  variant === "about"
    ? `${project.title} — About — ToyWebCreations`
    : `${project.title} — ToyWebCreations`;
---

<SiteLayout title={title} description={project.description} githubHref={project.sourceLink}>
  <div class="project-shell">
    <nav class="project-shell__subnav" aria-label="Project">
      <a href={demoHref} aria-current={variant === "demo" ? "page" : undefined}>Play</a>
      <a href={aboutHref} aria-current={variant === "about" ? "page" : undefined}>About</a>
      <a href={project.sourceLink} target="_blank" rel="noopener noreferrer">Source</a>
    </nav>
    <div class="project-shell__body">
      <slot />
    </div>
  </div>
</SiteLayout>

<style>
  .project-shell__subnav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .project-shell__subnav a {
    text-decoration: none;
    color: var(--color-text-muted);
  }

  .project-shell__subnav a:hover,
  .project-shell__subnav a[aria-current="page"] {
    color: var(--color-accent);
  }

  .project-shell__body {
    min-height: 12rem;
  }
</style>
