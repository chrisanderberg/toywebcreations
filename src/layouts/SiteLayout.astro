---
import SiteHeader from '../components/site/SiteHeader.astro';
import { ClientRouter } from 'astro:transitions';
import { withBasePath } from '../lib/site';
import '../styles/global.css';

const filmDissolve = {
  forwards: {
    old: [{ name: 'film-dissolve-out', duration: '0.35s', easing: 'ease-in', fillMode: 'both' }],
    new: [{ name: 'film-dissolve-in',  duration: '0.35s', easing: 'ease-out', fillMode: 'both', delay: '0.2s' }],
  },
  backwards: {
    old: [{ name: 'film-dissolve-out', duration: '0.35s', easing: 'ease-in', fillMode: 'both' }],
    new: [{ name: 'film-dissolve-in',  duration: '0.35s', easing: 'ease-out', fillMode: 'both', delay: '0.2s' }],
  },
};

interface Props {
  title: string;
  description?: string;
  githubLink?: string;
}

const {
  title,
  description = 'ToyWebCreations — interactive toy projects for curious people.',
  githubLink,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600&family=Source+Sans+3:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href={withBasePath(import.meta.env.BASE_URL, 'favicon.svg')} />
    <ClientRouter />
  </head>
  <body>
    <SiteHeader githubLink={githubLink} />
    <main transition:name="main-content" transition:animate={filmDissolve}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <div class="footer-inner">
          <div class="footer-rule-row">
            <span class="footer-rule" aria-hidden="true"></span>
            <span class="footer-ornament" aria-hidden="true">§</span>
            <span class="footer-rule" aria-hidden="true"></span>
          </div>
          <div class="footer-text-row">
            <span class="footer-text">ToyWebCreations</span>
            <span class="footer-sep">·</span>
            <span class="footer-text">Built with Astro</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - var(--header-height) - 60px);
  }

  .site-footer {
    border-top: none;
    padding: var(--space-8) 0;
    margin-top: var(--space-16);
    text-align: center;
  }

  .site-footer .container {
    display: flex;
    justify-content: center;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-rule-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    width: 100%;
    max-width: 320px;
  }

  .footer-rule {
    flex: 1;
    height: 1px;
    background: var(--border);
    display: block;
  }

  .footer-ornament {
    font-size: var(--text-lg);
    color: var(--phosphor-dim);
    line-height: 1;
  }

  .footer-text-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .footer-sep {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }
</style>
