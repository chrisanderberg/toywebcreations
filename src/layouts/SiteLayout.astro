---
import SiteHeader from '../components/site/SiteHeader.astro';
import { ClientRouter } from 'astro:transitions';
import { withBasePath } from '../lib/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  githubLink?: string;
}

const {
  title,
  description = 'ToyWebCreations — interactive toy projects for curious people.',
  githubLink,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <link rel="icon" type="image/svg+xml" href={withBasePath(import.meta.env.BASE_URL, 'favicon.svg')} />
    <ClientRouter />
  </head>
  <body>
    <SiteHeader githubLink={githubLink} />
    <main transition:name="main-content" transition:animate="fade">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <span class="footer-text">ToyWebCreations</span>
        <span class="footer-sep">·</span>
        <span class="footer-text">Built with Astro</span>
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - 120px);
  }

  .site-footer {
    border-top: none;
    padding: var(--space-8) 0;
    margin-top: var(--space-24);
    text-align: center;
  }

  .site-footer .container {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
  }

  .footer-text {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .footer-sep {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }
</style>
