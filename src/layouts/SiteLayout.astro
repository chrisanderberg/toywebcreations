---
import SiteHeader from '../components/site/SiteHeader.astro';
import { withBasePath } from '../lib/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  githubLink?: string;
}

const {
  title,
  description = 'ToyWebCreations — interactive toy projects for curious people.',
  githubLink,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={withBasePath(import.meta.env.BASE_URL, 'favicon.svg')} />
  </head>
  <body class="flicker">
    <SiteHeader githubLink={githubLink} />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <span class="footer-text">ToyWebCreations</span>
        <span class="footer-sep">·</span>
        <span class="footer-text">Built with Astro</span>
      </div>
    </footer>
  </body>
</html>

<style>
  main {
    min-height: calc(100vh - var(--header-height) - 60px);
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-5) 0;
    margin-top: var(--space-16);
  }

  .site-footer .container {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .footer-text {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .footer-sep {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }
</style>
