---
import type { ProjectMeta } from '../../lib/projects/types';
import { withBasePath } from '../../lib/site';

interface Props {
  projects: ProjectMeta[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
const isNew = (d?: string) => !!d && (Date.now() - new Date(d).getTime()) < 90 * 86400000;
---

<section class="featured-section">
  <div class="container">
    <h2 class="section-heading">Featured</h2>
    <p class="section-ornament">❦</p>
    <div class="featured-grid">
      {projects.map((project, index) => (
        <a href={withBasePath(base, `${project.slug}/`)} class={`featured-card${index === 0 ? ' featured-card--hero' : ''}${index === 3 ? ' featured-card--wide' : ''}`} aria-label={`Play ${project.title}`}>
          <div class="card-image-wrap">
            <img
              src={project.coverImage}
              alt={`${project.title} preview`}
              class="card-image"
              loading="lazy"
              decoding="async"
              width="640"
              height="360"
            />
            <div class="card-overlay">
              <span class="card-play">▶ Play</span>
            </div>
          </div>
          <div class="card-body">
            <h3 class="card-title">{project.title}</h3>
            {project.description && (
              <p class="card-desc">{project.description}</p>
            )}
            <div class="card-meta">
              {isNew(project.addedDate) && <span class="badge-new">New</span>}
              {project.playTime && <span class="chip">⏱ {project.playTime}</span>}
              {project.difficulty && (
                <span class="chip chip-difficulty" aria-label={`Difficulty ${project.difficulty} of 3`}>
                  {[1,2,3].map(n => <span class={`dot${n <= project.difficulty! ? ' dot--on' : ''}`} />)}
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    padding: var(--space-16) 0;
    border-bottom: 1px solid var(--border);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 300;
    color: var(--phosphor);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: var(--space-3);
  }

  .section-ornament {
    font-size: var(--text-xl);
    color: var(--phosphor-dim);
    text-align: center;
    margin-bottom: var(--space-10);
    line-height: 1;
  }

  /* Magazine spread: wide left column (portrait hero), narrower right stack */
  .featured-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    grid-template-rows: auto auto;
    gap: var(--space-5);
  }

  .featured-card {
    display: block;
    border: 1px solid var(--border-bright);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--bg-surface);
    box-shadow:
      inset 0 2px 8px rgba(26, 21, 16, 0.35),
      0 4px 16px rgba(0, 0, 0, 0.4);
    text-decoration: none;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base),
      opacity 0.4s ease;
    position: relative;
    opacity: 0;
    transform: translateY(16px);
  }

  .featured-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-card:nth-child(2) { transition-delay: 0.07s; }
  .featured-card:nth-child(3) { transition-delay: 0.14s; }
  .featured-card:nth-child(4) { transition-delay: 0.21s; }

  .featured-card:hover {
    border-color: var(--phosphor-dim);
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.5),
      0 2px 4px rgba(0, 0, 0, 0.3);
    transform: translateY(-2px);
  }

  /* Hero card: spans full left column, portrait crop */
  .featured-card--hero {
    grid-row: 1 / 3;
  }

  .featured-card--hero .card-image-wrap {
    aspect-ratio: 3 / 4;
  }

  /* 4th card: full-width horizontal spread */
  .featured-card--wide {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .featured-card--wide .card-image-wrap {
    aspect-ratio: unset;
    min-height: 180px;
  }

  .featured-card--wide .card-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-8);
  }

  .card-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-raised);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow), filter var(--transition-slow);
    filter: sepia(0.35) saturate(0.7) brightness(0.82) contrast(1.08) blur(0.3px);
  }

  .featured-card:hover .card-image {
    transform: scale(1.03);
    filter: sepia(0.08) saturate(0.95) brightness(1);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(26, 21, 16, 0.6);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .featured-card:hover .card-overlay {
    opacity: 1;
  }

  .card-play {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 300;
    font-style: italic;
    color: var(--phosphor);
    text-shadow: var(--text-deboss-strong);
    letter-spacing: 0.08em;
  }

  .card-body {
    padding: var(--space-5) var(--space-5) var(--space-6);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 300;
    font-style: italic;
    color: var(--phosphor);
    margin-bottom: var(--space-2);
    letter-spacing: 0.02em;
    transition: color var(--transition-fast);
  }

  .featured-card--hero .card-title {
    font-size: var(--text-3xl);
  }

  .featured-card:hover .card-title {
    color: var(--phosphor-bright);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: 1.6;
  }

  .featured-card.is-visible:hover {
    transform: translateY(-2px);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .badge-new {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--bg);
    background: var(--phosphor);
    padding: 1px 6px;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
    font-style: normal;
  }

  .chip-difficulty {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border-bright);
  }

  .dot--on {
    background: var(--phosphor-dim);
  }

  @media (max-width: 768px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .featured-card--hero {
      grid-row: auto;
    }
    .featured-card--hero .card-image-wrap {
      aspect-ratio: 16 / 9;
    }
    .featured-card--wide {
      grid-column: auto;
      grid-template-columns: 1fr;
    }
    .featured-card--wide .card-image-wrap {
      min-height: auto;
    }
    .featured-card--wide .card-body {
      padding: var(--space-5);
    }
  }
</style>

<script>
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  const cards = document.querySelectorAll('.featured-card');
  if (mq.matches) {
    cards.forEach(el => el.classList.add('is-visible'));
  } else {
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    cards.forEach(el => io.observe(el));
  }
</script>
