---
import type { ProjectMeta } from '../../lib/projects/types';

interface Props {
  projects: ProjectMeta[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="featured" aria-labelledby="featured-heading">
  <div class="featured__head">
    <h2 id="featured-heading" class="featured__title">Featured</h2>
    <p class="featured__sub">Start here — full demos, one click away.</p>
  </div>
  <ul class="featured__grid">
    {
      projects.map((project, index) => (
        <li class="featured__item" style={`--stagger: ${index * 0.07}s`}>
          <a class="featured__card" href={`${base}${project.slug}/`}>
            <span class="featured__glow" aria-hidden="true" />
            <span class="featured__media">
              <img
                src={project.coverImage}
                alt=""
                width="800"
                height="450"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span class="featured__body">
              <span class="featured__project-title">{project.title}</span>
              {project.description ? <span class="featured__desc">{project.description}</span> : null}
              <span class="featured__cta">
                Open demo
                <span class="featured__cta-arrow" aria-hidden="true">
                  →
                </span>
              </span>
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .featured {
    padding-bottom: var(--space-section);
  }

  .featured__head {
    margin-bottom: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1.5rem;
  }

  .featured__title {
    margin: 0;
    font-size: clamp(1.35rem, 2.5vw, 1.75rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-phosphor);
    text-shadow: var(--shadow-glow-sm);
  }

  .featured__sub {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text-muted);
    text-transform: none;
    letter-spacing: normal;
  }

  .featured__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(17rem, 1fr));
    gap: clamp(1.25rem, 3vw, 1.75rem);
  }

  .featured__item {
    animation: card-in 0.75s ease-out both;
    animation-delay: calc(0.12s + var(--stagger, 0s));
  }

  @keyframes card-in {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .featured__card {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    min-height: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-panel);
    color: inherit;
    text-decoration: none;
    overflow: hidden;
    transition:
      border-color 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .featured__card:hover {
    border-color: rgba(61, 255, 154, 0.45);
    box-shadow: var(--shadow-glow-md);
    transform: translateY(-3px);
  }

  .featured__card:focus-visible {
    outline: 2px solid var(--color-phosphor);
    outline-offset: 3px;
  }

  .featured__glow {
    position: absolute;
    inset: -40% -20%;
    background: radial-gradient(circle at 30% 0%, rgba(61, 255, 154, 0.12), transparent 55%);
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
  }

  .featured__card:hover .featured__glow,
  .featured__card:focus-visible .featured__glow {
    opacity: 1;
  }

  .featured__media {
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .featured__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.05) contrast(1.05);
    transition: transform 0.45s ease;
  }

  .featured__card:hover .featured__media img {
    transform: scale(1.04);
  }

  .featured__body {
    padding: 1.1rem 1.2rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .featured__project-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .featured__desc {
    font-size: 0.98rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .featured__cta {
    margin-top: auto;
    padding-top: 0.65rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-phosphor-dim);
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .featured__card:hover .featured__cta {
    color: var(--color-phosphor);
    text-shadow: var(--shadow-glow-sm);
  }

  .featured__cta-arrow {
    transition: transform 0.25s ease;
  }

  .featured__card:hover .featured__cta-arrow {
    transform: translateX(4px);
  }
</style>
