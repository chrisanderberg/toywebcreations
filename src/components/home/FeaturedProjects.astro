---
import type { ProjectMeta } from '../../lib/projects/types';
import { withBasePath } from '../../lib/site';

interface Props {
  projects: ProjectMeta[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
const isNew = (d?: string) => !!d && (Date.now() - new Date(d).getTime()) < 90 * 86400000;
---

<section class="featured-section">
  <div class="container">
    <h2 class="section-heading">
      <span class="heading-prefix">01</span>
      Featured
    </h2>
    <div class="featured-grid">
      {projects.map((project) => (
        <a href={withBasePath(base, `${project.slug}/`)} class="featured-card" aria-label={`Play ${project.title}`}>
          <div class="card-image-wrap">
            <img
              src={project.coverImage}
              alt={`${project.title} preview`}
              class="card-image"
              loading="lazy"
              decoding="async"
              width="640"
              height="360"
            />
            <div class="card-overlay">
              <span class="card-play">▶ PLAY</span>
            </div>
            <div class="card-scanlines" aria-hidden="true"></div>
          </div>
          <div class="card-body">
            <h3 class="card-title">{project.title}</h3>
            {project.description && (
              <p class="card-desc">{project.description}</p>
            )}
            <div class="card-meta">
              {isNew(project.addedDate) && <span class="badge-new">New</span>}
              {project.playTime && <span class="chip">⏱ {project.playTime}</span>}
              {project.difficulty && (
                <span class="chip chip-difficulty" aria-label={`Difficulty ${project.difficulty} of 3`}>
                  {[1,2,3].map(n => <span class={`dot${n <= project.difficulty! ? ' dot--on' : ''}`} />)}
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    padding: var(--space-20) 0;
    border-bottom: none;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--phosphor);
    margin-bottom: var(--space-10);
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--space-4);
    text-align: center;
  }

  .heading-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    letter-spacing: 0.1em;
    position: relative;
    top: -4px;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
  }

  .featured-card {
    display: block;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 20px;
    overflow: hidden;
    background: var(--bg-surface);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 4px 24px rgba(0, 0, 0, 0.3);
    text-decoration: none;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      background var(--transition-base),
      backdrop-filter var(--transition-base),
      transform var(--transition-base),
      opacity 0.4s ease;
    position: relative;
    opacity: 0;
    transform: translateY(16px);
  }

  .featured-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-card:nth-child(2) { transition-delay: 0.07s; }
  .featured-card:nth-child(3) { transition-delay: 0.14s; }
  .featured-card:nth-child(4) { transition-delay: 0.21s; }

  .featured-card:nth-child(2) { animation-delay: 0.1s; }
  .featured-card:nth-child(3) { animation-delay: 0.2s; }
  .featured-card:nth-child(4) { animation-delay: 0.3s; }

  .featured-card:hover {
    border-color: rgba(255, 255, 255, 0.22);
    border-top-color: rgba(255, 255, 255, 0.30);
    background: rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 8px 32px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    transform: translateY(-3px);
  }

  .card-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-raised);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow), filter var(--transition-slow);
    filter: brightness(0.9);
  }

  .featured-card:hover .card-image {
    transform: scale(1.03);
    filter: saturate(1) brightness(1);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(12, 18, 32, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .featured-card:hover .card-overlay {
    opacity: 1;
  }

  .card-play {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--phosphor-bright);
    text-shadow: none;
    letter-spacing: 0.12em;
  }

  .card-scanlines {
    display: none;
  }

  .card-body {
    padding: var(--space-6) var(--space-6) var(--space-8);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: var(--phosphor);
    margin-bottom: var(--space-2);
    letter-spacing: 0.04em;
    transition: text-shadow var(--transition-fast);
  }

  .featured-card:hover .card-title {
    color: var(--phosphor-bright);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: 1.6;
  }

  .featured-card.is-visible:hover {
    transform: translateY(-3px);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .badge-new {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    background: var(--phosphor);
    padding: 1px 6px;
    border-radius: 3px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .chip-difficulty {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
  }

  .dot--on {
    background: var(--phosphor);
  }

  @media (max-width: 640px) {
    .featured-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>

<noscript>
  <style>
    .featured-card {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  const cards = document.querySelectorAll('.featured-card');
  if (mq.matches) {
    cards.forEach(el => el.classList.add('is-visible'));
  } else {
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    cards.forEach(el => io.observe(el));
  }
</script>
