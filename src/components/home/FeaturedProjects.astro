---
import type { ProjectMeta } from '../../lib/projects/types';
import { withBasePath } from '../../lib/site';

interface Props {
  projects: ProjectMeta[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
const isNew = (d?: string) => !!d && (Date.now() - new Date(d).getTime()) < 90 * 86400000;
---

<section class="featured-section">
  <div class="container">
    <h2 class="section-heading">
      <span class="heading-prefix">01</span>
      Featured
    </h2>
    <hr class="section-rule" aria-hidden="true" />
    <div class="featured-grid">
      {projects.map((project, index) => (
        <a href={withBasePath(base, `${project.slug}/`)} class={`featured-card${index === 0 ? ' featured-card--hero' : ''}${index === 3 ? ' featured-card--wide' : ''}`} aria-label={`Play ${project.title}`}>
          <div class="card-image-wrap">
            <img
              src={project.coverImage}
              alt={`${project.title} preview`}
              class="card-image"
              loading="lazy"
              decoding="async"
              width="640"
              height="360"
            />
            <div class="card-overlay">
              <span class="card-play">▶ PLAY</span>
            </div>
          </div>
          <div class="card-body">
            <h3 class="card-title">{project.title}</h3>
            {project.description && (
              <p class="card-desc">{project.description}</p>
            )}
            <div class="card-meta">
              {isNew(project.addedDate) && <span class="badge-new">New</span>}
              {project.playTime && <span class="chip">⏱ {project.playTime}</span>}
              {project.difficulty && (
                <span class="chip chip-difficulty" aria-label={`Difficulty ${project.difficulty} of 3`}>
                  {[1,2,3].map(n => <span class={`dot${n <= project.difficulty! ? ' dot--on' : ''}`} />)}
                </span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    padding: var(--space-16) 0;
    border-bottom: 2px solid var(--border-bright);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-6);
    display: flex;
    align-items: center;
    gap: var(--space-4);
    border-left: 5px solid var(--phosphor);
    padding-left: var(--space-4);
  }

  .heading-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    background: var(--phosphor);
    color: #fff;
    padding: 2px 6px;
    letter-spacing: 0.05em;
  }

  .section-rule {
    border: none;
    height: 4px;
    background: var(--phosphor);
    width: 120px;
    margin-bottom: var(--space-10);
    margin-left: calc(var(--space-4) + 5px);
  }

  /* Asymmetric grid: hero left (2fr), stack right (1fr) */
  .featured-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto auto;
    gap: var(--space-5);
  }

  .featured-card {
    display: block;
    border: 2px solid var(--border-bright);
    border-radius: 0;
    overflow: hidden;
    background: var(--bg-surface);
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--border-bright);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      transform var(--transition-fast),
      opacity 0.4s ease;
    position: relative;
    opacity: 0;
    transform: translateY(16px);
  }

  .featured-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .featured-card:nth-child(2) { transition-delay: 0.07s; }
  .featured-card:nth-child(3) { transition-delay: 0.14s; }
  .featured-card:nth-child(4) { transition-delay: 0.21s; }

  .featured-card:hover {
    border-color: var(--phosphor);
    box-shadow: 6px 6px 0 var(--phosphor);
    transform: translate(-1px, -1px);
  }

  .featured-card.is-visible:hover {
    transform: translate(-1px, -1px);
  }

  /* Hero card spans full left column height */
  .featured-card--hero {
    grid-row: 1 / 3;
  }

  .featured-card--hero .card-image-wrap {
    aspect-ratio: 4 / 3;
  }

  /* 4th card spans full width below */
  .featured-card--wide {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .featured-card--wide .card-image-wrap {
    aspect-ratio: unset;
    min-height: 200px;
  }

  .featured-card--wide .card-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-8);
  }

  .card-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-raised);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
    filter: none;
  }

  .featured-card:hover .card-image {
    transform: scale(1.03);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--phosphor);
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .featured-card:hover .card-overlay {
    opacity: 0.9;
  }

  .card-play {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    color: #fff;
    text-shadow: none;
    letter-spacing: 0.12em;
    font-weight: 700;
  }

  .card-body {
    padding: var(--space-5) var(--space-5) var(--space-6);
  }

  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .featured-card--hero .card-title {
    font-size: var(--text-3xl);
  }

  .featured-card:hover .card-title {
    color: var(--phosphor);
  }

  .card-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: 1.6;
  }

  .featured-card.is-visible:hover {
    transform: translate(-1px, -1px);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .badge-new {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--bg);
    background: var(--phosphor);
    padding: 1px 6px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .chip-difficulty {
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--border-bright);
  }

  .dot--on {
    background: var(--phosphor);
  }

  @media (max-width: 768px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }
    .featured-card--hero {
      grid-row: auto;
    }
    .featured-card--hero .card-image-wrap {
      aspect-ratio: 16 / 9;
    }
    .featured-card--wide {
      grid-column: auto;
      grid-template-columns: 1fr;
    }
    .featured-card--wide .card-image-wrap {
      min-height: auto;
    }
    .featured-card--wide .card-body {
      padding: var(--space-5);
    }
  }
</style>

<script>
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  const cards = document.querySelectorAll('.featured-card');
  if (mq.matches) {
    cards.forEach(el => el.classList.add('is-visible'));
  } else {
    const io = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    cards.forEach(el => io.observe(el));
  }
</script>
