---
import type { ProjectMeta } from '../../lib/projects/types';
import { withBasePath } from '../../lib/site';

interface Props {
  projects: ProjectMeta[];
}

const { projects } = Astro.props;
const base = import.meta.env.BASE_URL;
const isNew = (d?: string) => !!d && (Date.now() - new Date(d).getTime()) < 90 * 86400000;
const allTags = [...new Set(projects.flatMap(p => p.tags ?? []))].sort();
---

<section class="all-projects-section">
  <div class="container">
    <h2 class="section-heading">
      <span class="heading-prefix">02</span>
      All Projects
    </h2>
    <div class="filter-bar" role="group" aria-label="Filter by tag">
      <button class="filter-btn filter-btn--active" data-tag="all">All</button>
      {allTags.map(tag => (
        <button class="filter-btn" data-tag={tag}>{tag}</button>
      ))}
    </div>
    <div class="projects-grid">
      {projects.map((project, index) => (
        <a href={withBasePath(base, `${project.slug}/`)} class="project-card" aria-label={project.title}
           data-tags={project.tags?.join(',') ?? ''}
           style={`animation-delay: ${index * 0.07}s`}>
          <div class="project-icon-wrap">
            <img
              src={project.icon}
              alt=""
              class="project-icon"
              loading="lazy"
              decoding="async"
              width="52"
              height="52"
              aria-hidden="true"
            />
          </div>
          <div class="project-info">
            <span class="project-title">{project.title}</span>
            {project.description && (
              <span class="project-desc">{project.description}</span>
            )}
            <div class="card-meta">
              {isNew(project.addedDate) && <span class="badge-new">New</span>}
              {project.playTime && <span class="chip">⏱ {project.playTime}</span>}
            </div>
          </div>
          <span class="project-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .all-projects-section {
    padding: var(--space-16) 0 var(--space-20);
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    color: var(--phosphor);
    margin-bottom: var(--space-10);
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    justify-content: center;
    text-align: center;
  }

  .heading-prefix {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    letter-spacing: 0.1em;
    position: relative;
    top: -4px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .project-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-6);
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 16px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    text-decoration: none;
    transition:
      background var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base),
      opacity 0.4s ease;
  }

  .project-card:hover {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.14);
    border-top-color: rgba(255, 255, 255, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.10),
      0 4px 16px rgba(0, 0, 0, 0.2);
    transform: translateY(-2px);
  }

  .project-card:hover .project-title {
    color: var(--phosphor-bright);
  }

  .project-card:hover .project-arrow {
    color: var(--phosphor-bright);
    transform: translateX(4px);
  }

  .project-icon-wrap {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-top: 1px solid rgba(255, 255, 255, 0.20);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .project-icon {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .project-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .project-title {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0.02em;
    transition: color var(--transition-fast);
  }

  .project-desc {
    font-size: var(--text-sm);
    color: var(--text-dim);
    line-height: 1.5;
  }

  .project-arrow {
    font-size: var(--text-lg);
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .filter-bar {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: var(--space-1) var(--space-3);
    cursor: pointer;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-radius: 9999px;
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .filter-btn:hover {
    color: var(--phosphor);
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
  }

  .filter-btn--active {
    color: var(--phosphor-bright);
    border-color: var(--phosphor-dim);
    background: rgba(59, 130, 246, 0.15);
  }

  .project-card {
    opacity: 0;
    transform: translateY(12px);
  }

  .project-card.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .project-card:nth-child(2) { transition-delay: 0.07s; }
  .project-card:nth-child(3) { transition-delay: 0.14s; }
  .project-card:nth-child(4) { transition-delay: 0.21s; }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-1);
    flex-wrap: wrap;
  }

  .badge-new {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    background: var(--phosphor);
    padding: 0px 5px;
    border-radius: 2px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .chip {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<noscript>
  <style>
    .project-card {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  const initAllProjects = () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.project-card');

    buttons.forEach((button) => {
      button.onclick = () => {
        const activeTag = button.dataset.tag ?? 'all';

        buttons.forEach((candidate) => {
          candidate.classList.toggle('filter-btn--active', candidate === button);
        });

        cards.forEach((card) => {
          const rawTags = card.dataset.tags?.trim() ?? '';
          const tags = rawTags
            ? rawTags
                .split(',')
                .map((tag) => tag.trim())
                .filter(Boolean)
            : [];

          // Keep untagged projects visible so filtering does not hide unfinished metadata.
          card.style.display =
            activeTag === 'all' || tags.length === 0 || tags.includes(activeTag) ? '' : 'none';
        });
      };
    });

    cards.forEach((card) => {
      card.classList.remove('is-visible');
    });

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cards.forEach((card) => {
        card.classList.add('is-visible');
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );

    cards.forEach((card) => {
      observer.observe(card);
    });
  };

  document.addEventListener('astro:page-load', initAllProjects);
  initAllProjects();
</script>
