---
---

<section class="site-intro">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-inner">
        <h1 class="intro-headline">
          Small projects.<br />
          Strange ideas.<br />
          All interactive.
        </h1>
        <p class="intro-body">
          ToyWebCreations is a collection of focused, playable web experiments —
          puzzles, simulations, generators, and visual curiosities.
          Each one exists because it was interesting to build.
          Pick something. Try it.
        </p>
        <p class="intro-scroll-hint">
          <span class="hint-char">↓</span> scroll to browse
        </p>
      </div>
      <div class="intro-geo" aria-hidden="true">
        <div class="geo-circle"></div>
        <div class="geo-rect"></div>
        <div class="geo-triangle"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .site-intro {
    padding: var(--space-20) 0 var(--space-16);
    border-bottom: 4px solid var(--border-bright);
    position: relative;
    overflow: hidden;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: center;
  }

  .intro-inner {
    position: relative;
  }

  .intro-headline {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, var(--text-7xl));
    font-weight: 700;
    color: var(--text);
    text-shadow: none;
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-8);
    border-left: 5px solid var(--phosphor);
    padding-left: var(--space-6);
  }

  .intro-body {
    font-size: var(--text-lg);
    color: var(--text);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: var(--space-10);
    padding-left: calc(var(--space-6) + 5px);
  }

  .intro-scroll-hint {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.1em;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding-left: calc(var(--space-6) + 5px);
  }

  .hint-char {
    animation: bounce 2s ease-in-out infinite;
    display: inline-block;
  }

  /* Geometric composition */
  .intro-geo {
    position: relative;
    height: 280px;
  }

  .geo-circle {
    position: absolute;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: var(--phosphor);
    top: 0;
    right: 0;
  }

  .geo-rect {
    position: absolute;
    width: 100px;
    height: 72px;
    background: var(--phosphor-dim);
    bottom: 50px;
    left: 0;
  }

  .geo-triangle {
    position: absolute;
    width: 0;
    height: 0;
    border-left: 55px solid transparent;
    border-right: 55px solid transparent;
    border-bottom: 92px solid var(--phosphor-muted);
    bottom: 0;
    right: 48px;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(4px); }
  }

  @media (max-width: 768px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
    .intro-geo {
      display: none;
    }
    .intro-body,
    .intro-scroll-hint {
      padding-left: calc(var(--space-6) + 5px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hint-char {
      animation: none;
    }
  }
</style>
