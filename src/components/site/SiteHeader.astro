---
import { REPO_ROOT } from '../../lib/github';
import { withBasePath } from '../../lib/site';

interface Props {
  githubLink?: string;
}

const { githubLink = REPO_ROOT } = Astro.props;
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;
const isHome  = path === base || path === `${base}/` || path === '/';
const isAbout = path.includes('/about');
---

<header class="site-header" transition:name="site-header" transition:persist>
  <div class="header-inner">
    <nav class="header-nav header-nav--left" aria-label="Site navigation">
      <a href={withBasePath(base)} class={`nav-link${isHome ? ' nav-link--active' : ''}`} aria-current={isHome ? 'page' : undefined}>Home</a>
      <a href={withBasePath(base, 'about/')} class={`nav-link${isAbout ? ' nav-link--active' : ''}`} aria-current={isAbout ? 'page' : undefined}>About</a>
    </nav>
    <a href={withBasePath(base)} class="banner" aria-label="ToyWebCreations — Home">
      <span class="banner-rule" aria-hidden="true"></span>
      <span class="banner-name">ToyWebCreations</span>
      <span class="banner-rule" aria-hidden="true"></span>
    </a>
    <nav class="header-nav header-nav--right" aria-label="External links">
      <a
        href={githubLink}
        class="nav-link nav-link--github"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View source on GitHub (opens in new tab)"
      >
        <svg class="github-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: 52px;
    background: rgba(26, 21, 16, 0.95);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .header-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
  }

  .banner {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 300;
    color: var(--phosphor);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .banner:hover {
    color: var(--phosphor-bright);
  }

  .banner-rule {
    display: block;
    width: 40px;
    height: 1px;
    background: var(--phosphor-dim);
    flex-shrink: 0;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    flex: 1;
  }

  .header-nav--right {
    justify-content: flex-end;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border: none;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .nav-link:hover {
    color: var(--phosphor);
  }

  .nav-link--active {
    color: var(--phosphor);
    text-decoration: underline;
    text-decoration-color: var(--phosphor-dim);
    text-underline-offset: 3px;
  }

  .nav-link--github {
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: var(--space-1) var(--space-3);
  }

  .nav-link--github:hover {
    color: var(--phosphor);
    border-color: var(--border-bright);
  }

  .github-icon {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .header-inner {
      gap: var(--space-4);
    }
    .banner-rule {
      display: none;
    }
    .banner {
      font-size: var(--text-base);
    }
    .nav-link {
      padding: var(--space-1) var(--space-2);
    }
  }
</style>
